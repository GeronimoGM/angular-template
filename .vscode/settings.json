{
  "editor.formatOnSave": true,
  "tailwindCSS.classFunctions": ["hlm", "cva", "classes"],
  "tailwindCSS.experimental.classRegex": [
    "class: ['`]([^'`]*)['`]",
    ["'\\[class\\]': '([^']*)'", "\"([^\"]*)\""],
    ["'\\[class\\]': `([^`]*)`", "'([^']*)'"],
    "\\[class\\.([^\\]]*)\\]",
    "'animate\\.(?:enter|leave)': '([^']*)'"
  ]
}
